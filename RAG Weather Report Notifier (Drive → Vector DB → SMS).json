          "messageValues": [
            {
              "message": "You are a meteorology assistant. The provided text is a weather report that was just revised. Write a very short plain-text SMS status of no more than 4 short lines and under 300 characters total. Line 1: location and forecast period. Line 2: temperature. Line 3: precipitation and wind. Line 4: any warning/alert or the key change (or 'No alerts'). Be terse, no markdown, no emojis, no preamble."
            }
          ]
        },
        "batching": {}
      },
